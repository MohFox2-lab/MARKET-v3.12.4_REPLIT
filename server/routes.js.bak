    if (!symbol) return res.status(400).json({ ok:false, error:'BAD_REQUEST', message_ar:'يلزم symbol.' });

    const mode = String(req.query.mode || 'manual').trim().toLowerCase();
    const s = await getSentiment({ pool, symbol, market, mode });
    return res.json(s);
  } catch (e) {
    return res.status(500).json({ ok:false, error:'SERVER_ERROR' });
  }
});

router.post('/api/sentiment/manual', async (req, res) => {
  try {
    const symbol = String(req.body?.symbol || '').trim();
    const market = String(req.body?.market || 'US').trim().toUpperCase();
    const hype = Number(req.body?.hype_score);
    const sev = Number(req.body?.news_severity);
    if (!symbol || !Number.isFinite(hype) || !Number.isFinite(sev)) {
      return res.status(400).json({ ok:false, error:'BAD_REQUEST', message_ar:'يلزم symbol + hype_score + news_severity.' });
    }
    const saved = await setManualSentiment({ pool, symbol, market, hype_score: hype, news_severity: sev, sources: req.body?.sources || ['manual'] });
    return res.json(saved);
  } catch (e) {
    return res.status(500).json({ ok:false, error:'SERVER_ERROR' });
  }
});


